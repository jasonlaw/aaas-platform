_config_version: 1

model:
  provider: openrouter
  default: openai/gpt-4.1-mini

# Optional cross-provider failover for admin Hermes. Only present if the
# operator gave a fallback provider during setup-admin-hermes "Ask The
# Operator". Left commented out exactly as shipped here if declined.
# Hermes switches to this provider:model, turn-scoped, if the primary
# provider fails (rate limits, server errors, auth failures). See
# https://hermes-agent.nousresearch.com/docs/user-guide/features/fallback-providers
# fallback_providers:
#   - provider: {{FALLBACK_MODEL_PROVIDER}}
#     model: {{FALLBACK_MODEL_NAME}}

# Native Hermes memory disabled - replaced by Mnemosyne.
memory:
  provider: mnemosyne
  memory_enabled: false
  user_profile_enabled: false
  mnemosyne:
    auto_sleep: true
    sleep_threshold: 20

terminal:
  backend: local

display:
  tool_progress: off
  busy_ack_detail: off
  cleanup_progress: true

dashboard:
  host: 127.0.0.1
  port: 9119

# Telegram gateway is optional for admin Hermes. If the operator declined
# Telegram during setup-admin-hermes, leave this block absent/commented.
# NOTE: home_chat_id below may or may not be where this Hermes version
# actually persists the home channel. Never fill this in by hand — always
# set the home channel via `hermes config set TELEGRAM_HOME_CHANNEL <id>`
# (see skills/configure-telegram-channel-admin.md) and let Hermes decide
# whether that lands here or in .env. Verify with `hermes config get
# TELEGRAM_HOME_CHANNEL`, not by reading this file directly.
# gateway:
#   platforms:
#     telegram:
#       home_chat_id: ""
#       gateway_restart_notification: true
