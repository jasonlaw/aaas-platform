# Hermes admin secrets - DO NOT COMMIT THIS FILE
# Real values go in /opt/aaas/platform/admin/.env.
#
# IMPORTANT: Real LLM API keys must NEVER be stored here.
# They are managed exclusively in Agent Vault (admin-vault).
# The provider key variable below must always hold the placeholder value
# after setup-admin-hermes completes. The real key lives only in Agent Vault;
# the proxy intercepts LLM calls and injects it at the network layer.

HERMES_HOME=/opt/aaas/platform/admin
MNEMOSYNE_DATA_DIR=/opt/aaas/platform/admin/mnemosyne/data

# LLM provider key — set to placeholder after Agent Vault provisioning.
# DO NOT replace this with a real key. Run setup-admin-hermes to provision.
OPENROUTER_API_KEY=routed-via-agent-vault
# OPENAI_API_KEY=routed-via-agent-vault
# ANTHROPIC_API_KEY=routed-via-agent-vault
# NOUS_API_KEY=routed-via-agent-vault
# OPENCODE_API_KEY=routed-via-agent-vault

# Agent Vault proxy — injected by setup-admin-hermes during provisioning.
# Admin Hermes runs on the host (not in Docker), so the proxy address is
# localhost rather than the agent-vault container hostname.
# Only the LLM provider host is routed through the proxy; NO_PROXY keeps
# everything else on a direct connection so Agent Vault never sees traffic
# it was not scoped to handle.
HTTP_PROXY=http://<admin-vault-token>@localhost:14322
HTTPS_PROXY=http://<admin-vault-token>@localhost:14322
NO_PROXY=localhost,127.0.0.1
AGENT_VAULT_TOKEN=<admin-vault-token>
AGENT_VAULT_VAULT=admin-vault
# Python SSL must trust the Agent Vault MITM CA installed on the host.
SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt

# Dashboard remote access should not be enabled by default.
# If binding the dashboard to a non-loopback address, configure strong auth.
# HERMES_DASHBOARD_BASIC_AUTH_USERNAME=
# HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=
# HERMES_DASHBOARD_BASIC_AUTH_SECRET=
