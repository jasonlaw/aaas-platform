# Tenant secrets — DO NOT COMMIT THIS FILE
# This file documents required secret keys (values are empty)
# Real values go in .env (gitignored)

# LLM provider API key placeholder.
# The real key is stored in Agent Vault — never put it here.
# This placeholder exists so the provider SDK initialises without error;
# Agent Vault's MITM proxy replaces it with the real key on every outbound request.
# Examples (uncomment the one matching the tenant's provider):
OPENROUTER_API_KEY=routed-via-agent-vault
# OPENAI_API_KEY=routed-via-agent-vault
# ANTHROPIC_API_KEY=routed-via-agent-vault
# NOUS_API_KEY=routed-via-agent-vault
# OPENCODE_ZEN_API_KEY=routed-via-agent-vault
# OPENCODE_GO_API_KEY=routed-via-agent-vault

# Fallback LLM provider API key placeholder — only present if the operator
# gave a fallback provider during onboard-tenant step 1 (optional; see
# config.yaml's fallback_providers block and provision-tenant-vault.md
# step 2.1/4.1). Uncomment and set to the fallback provider's own env var
# name, same placeholder pattern as the primary key above. Leave commented
# out if no fallback provider was configured.
# <FALLBACK_PROVIDER_ENV_VAR>=routed-via-agent-vault

TELEGRAM_BOT_TOKEN=
# Comma-separated numeric Telegram user IDs allowed to use this tenant bot
TELEGRAM_ALLOWED_USERS=
# Numeric ID of the single primary contact for Hermes-initiated messages
# (alerts, restart notifications) — one owner ID, never a list. Same
# convention as admin Hermes (see setup-admin-hermes.md Step 3.1): if
# TELEGRAM_ALLOWED_USERS has exactly one ID, use it here automatically;
# if it has more than one, ask the owner which one during onboarding.
TELEGRAM_HOME_CHANNEL=

# Pin the Hermes home directory to the persistent tenant volume. This must
# match the HERMES_HOME used by the onboarding/activation `docker exec`
# commands (see onboard-tenant.md step 12) so the long-running gateway
# process reads config/memory state from the same place that step wrote it.
HERMES_HOME=/opt/data

# Keep Mnemosyne runtime data inside the tenant volume
MNEMOSYNE_DATA_DIR=/opt/data/mnemosyne/data

# Agent Vault proxy — injected by provision-tenant-vault.sh during onboarding.
# Do not set these manually; the script writes the correct per-tenant values.
# The token is embedded as the Basic auth username so httpx/openai SDK sends
# Proxy-Authorization on every CONNECT. Agent Vault port 14322 requires it.
#
# The proxy hostname is the per-tenant forwarding sidecar
# (agent-vault-proxy-{tenant-id}), NOT the agent-vault container directly.
# Tenants are on an isolated per-tenant network (hermes-{tenant-id}-net) and
# cannot reach agent-vault directly — only the sidecar bridges the gap.
# provision-tenant-vault.sh fills in the correct sidecar name and token.
HTTP_PROXY=http://<AGENT_VAULT_TOKEN>@agent-vault-proxy-<TENANT_ID>:14322
HTTPS_PROXY=http://<AGENT_VAULT_TOKEN>@agent-vault-proxy-<TENANT_ID>:14322
# Hosts that bypass the proxy entirely (non-LLM traffic, e.g. Telegram).
# provision-tenant-vault.sh fills this in with api.telegram.org,localhost,127.0.0.1;
# only the registered LLM provider host should go through the proxy.
NO_PROXY=
# AGENT_VAULT_ADDR is intentionally not set. Tenant containers have no
# legitimate reason to call Agent Vault's management API (:14321) - only the
# proxy port (:14322, used implicitly above) is needed. This tenant's
# isolated network also makes :14321 unreachable from this container.
AGENT_VAULT_TOKEN=
AGENT_VAULT_VAULT=
# Required so Python's SSL context trusts the Agent Vault MITM CA installed
# by the Dockerfile's update-ca-certificates step (certifi doesn't include it).
SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt

# DISCORD_BOT_TOKEN=          # uncomment when Discord added
# WHATSAPP_BRIDGE_TOKEN=      # uncomment when WhatsApp added

# Admin Hermes contact — lets this tenant agent reach admin Hermes for
# support requests, operator alerts, and LLM key change requests
# (see skills/tenant-contact-admin.md, copied into this tenant's
# /opt/data/skills/ during onboarding). This is outbound-only: the tenant
# agent calls admin Hermes's API server, it does not run one of its own.
# Same value for every tenant, copied from admin-hermes/.env during
# onboarding. provision-tenant-vault.sh sets NO_PROXY to include
# localhost,127.0.0.1, so this call bypasses the Agent Vault proxy.
ADMIN_HERMES_API_URL=http://127.0.0.1:8642/v1
ADMIN_HERMES_API_KEY=
